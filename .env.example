# Copy to .env for local development.
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./data/idlcooking.sqlite3

# Required before starting the Telegram bot.
TELEGRAM_BOT_TOKEN=

# Optional local Ollama companion.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=llava
